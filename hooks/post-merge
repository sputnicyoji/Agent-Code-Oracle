#!/bin/sh
#
# Code Oracle post-merge hook
#
# Runs the freshness checker after each git merge to flag contracts
# that may be stale due to code changes.
#
# Install:
#   cp hooks/post-merge .git/hooks/post-merge
#   chmod +x .git/hooks/post-merge
#
# Configuration: reads oracle.config.json from repo root.
# Non-blocking: always exits 0. Stale contracts are reported, not errors.
#

REPO_ROOT="$(git rev-parse --show-toplevel)"
CONFIG="$REPO_ROOT/oracle.config.json"

if [ ! -f "$CONFIG" ]; then
    exit 0
fi

# Check Python is available
if ! command -v python3 >/dev/null 2>&1; then
    if ! command -v python >/dev/null 2>&1; then
        exit 0
    fi
    PYTHON=python
else
    PYTHON=python3
fi

SYNC_SCRIPT="$REPO_ROOT/scripts/oracle_sync.py"

if [ ! -f "$SYNC_SCRIPT" ]; then
    exit 0
fi

echo "[Code Oracle] Running sync after merge..."

# Log stderr to a file instead of /dev/null. Sync is advisory (we still exit 0)
# but silently throwing away every error means a broken script -- import
# error, missing module, NameError on a malformed contract -- goes undetected
# until somebody notices reports stopped updating. The log file gives a
# forensic trail without making the hook block the merge.
LOG_DIR="$REPO_ROOT/.claude/context"
mkdir -p "$LOG_DIR" 2>/dev/null
LOG_FILE="$LOG_DIR/oracle-sync.log"

$PYTHON "$SYNC_SCRIPT" --config "$CONFIG" --report "$LOG_DIR/oracle-sync-report.json" 2>>"$LOG_FILE"
SYNC_RC=$?

if [ $SYNC_RC -ne 0 ]; then
    echo "[Code Oracle] sync exited rc=$SYNC_RC; see $LOG_FILE"
fi

# Always exit 0 — freshness check is advisory, not a gate
exit 0
