{
  "project_name": "MyProject",
  "source_roots": ["src/"],
  "include": ["**/*.cs", "**/*.go", "**/*.ts", "**/*.tsx", "**/*.py", "**/*.rs"],
  "exclude": ["**/generated/**", "**/vendor/**", "**/node_modules/**", "**/__pycache__/**"],
  "scanned_modules": {
    "PaymentService": {
      "source_root": "src/PaymentService/",
      "contract_output": "docs/contracts/payment-service.json"
    },
    "UserAuth": {
      "source_root": "src/UserAuth/",
      "contract_output": "docs/contracts/user-auth.json"
    }
  },
  "contract_paths": [
    "docs/contracts/payment-service.json",
    "docs/contracts/user-auth.json"
  ],
  "graph_provider": {
    "type": "repomap_l3",
    "path": ".claude/context/repomap-L3-relations.md"
  },
  "sync_report": ".claude/context/oracle-sync-report.json",
  "quality_gate": {
    "min_effective": 5,
    "max_contracts": 30,
    "min_high_value_ratio": 0.5,
    "require_evidence_for": ["blast_radius"]
  }
}
